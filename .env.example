# KYC Multi-Provider Document Processor — Environment Variables
# Copy this file to .env and fill in your API keys.
#
# Only the provider you intend to use needs a key.
# Set KYC_PROVIDER to override the default from providers.yaml.

# --- Provider selection (optional) ---
# KYC_PROVIDER=openrouter

# --- API Keys ---
OPENROUTER_API_KEY=your-openrouter-key-here
PARASAIL_API_KEY=your-parasail-key-here
OPENAI_API_KEY=your-openai-key-here
GOOGLE_API_KEY=your-google-key-here
ANTHROPIC_API_KEY=your-anthropic-key-here
FIREWORKS_API_KEY=your-fireworks-key-here
TOGETHER_API_KEY=your-together-key-here

# --- OpenRouter optional headers ---
# OPENROUTER_SITE_URL=https://github.com/databased
# OPENROUTER_APP_NAME=KYC Document Processor
